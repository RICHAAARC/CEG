{
  "templates": [
    {
      "backend_id": "external_sd_watermark_backend",
      "command_template": [
        "python",
        "{image_generation_root}/scripts/run_pilot_image_generation_backend.py",
        "--prompt-plan",
        "{prompt_plan_path}",
        "--out",
        "{output_root}",
        "--model-config",
        "{model_config_path}",
        "--external-command-json-file",
        "{external_backend_command_json_path}"
      ],
      "output_path_template": "{output_root}",
      "working_directory_template": "{image_generation_root}",
      "timeout_seconds": 7200
    }
  ]
}
