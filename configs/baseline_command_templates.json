{
  "templates": [
    {
      "baseline_id": "tree_ring",
      "command_template": [
        "python",
        "{baseline_root}/tree_ring/run_ceg_eval.py",
        "--events",
        "{events_path}",
        "--output",
        "{output_root}/tree_ring_observations.json"
      ],
      "output_path_template": "{output_root}/tree_ring_observations.json",
      "working_directory_template": "{baseline_root}/tree_ring",
      "timeout_seconds": 7200
    },
    {
